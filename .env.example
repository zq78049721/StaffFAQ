# LLM 配置
# 提供商选择：ollama（本地）或 zhipu（云端）
LLM_PROVIDER=ollama

# 模型选择
# Ollama 推荐模型：qwen2.5:1.5b（首选）, qwen2.5:0.5b（更轻量）, gemma2:2b
# 智谱AI 推荐模型：glm-4-flash
LLM_MODEL=qwen2.5:1.5b

# 智谱AI API Key（仅当 LLM_PROVIDER=zhipu 时需要）
# 请前往 https://open.bigmodel.cn/ 获取
ZHIPU_API_KEY=your_zhipu_api_key_here

# 可选配置
# TEMPERATURE=0.7