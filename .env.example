# LLM 配置
# 提供商选择：ollama（本地）、deepseek（推荐）或 zhipu（云端）
LLM_PROVIDER=deepseek

# 模型选择
# DeepSeek 推荐模型：deepseek-chat（首选，性价比高）
# Ollama 推荐模型：qwen2.5:1.5b（首选）, qwen2.5:0.5b（更轻量）
# 智谱AI 推荐模型：glm-4-flash
LLM_MODEL=deepseek-chat

# DeepSeek API Key（当 LLM_PROVIDER=deepseek 时需要）
# 请前往 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 智谱AI API Key（仅当 LLM_PROVIDER=zhipu 时需要）
# 请前往 https://open.bigmodel.cn/ 获取
ZHIPU_API_KEY=your_zhipu_api_key_here

# 可选配置
# TEMPERATURE=0.7